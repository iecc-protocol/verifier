{
  "name": "@iecc/verifier",
  "version": "1.0.0",
  "description": "Open source verification logic for IECC digital credentials",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format cjs,esm --dts",
    "test": "vitest",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "credential",
    "verification",
    "cryptography",
    "ed25519",
    "iecc",
    "trust"
  ],
  "author": "IECC Consortium",
  "license": "MIT",
  "bin": {
    "iecc-verify": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "dependencies": {
    "@noble/ed25519": "^2.0.0",
    "@noble/hashes": "^1.3.3",
    "json-canon": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
